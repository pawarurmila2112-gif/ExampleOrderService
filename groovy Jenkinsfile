pipeline {
    agent {
        // Use the official .NET 8 SDK image. This requires Docker to be available on the Jenkins agent.
        docker {
            image 'mcr.microsoft.com/dotnet/sdk:8.0'
            // mount docker socket if you intend to build/push images from inside the container
            args '--privileged -v /var/run/docker.sock:/var/run/docker.sock'
        }
    }

    environment {
        DOTNET_CLI_TELEMETRY_OPTOUT = '1'
        DOTNET_SKIP_FIRST_TIME_EXPERIENCE = '1'

        // Optional environment variables you can set in Jenkins:
        // DOCKER_REGISTRY - e.g. registry.example.com (if empty, push stage will be skipped)
        // DOCKER_IMAGE - image name (default: exampleorderservice)
        // DOCKER_CREDENTIALS_ID - Jenkins credentials id for registry username/password
        DOCKER_IMAGE = "${env.DOCKER_IMAGE ?: 'exampleorderservice'}"
        DOCKER_REGISTRY = "${env.DOCKER_REGISTRY ?: ''}"
        DOCKER_CREDENTIALS_ID = "${env.DOCKER_CREDENTIALS_ID ?: ''}"
    }

    stages {
        stage('Checkout') {
            steps { 
                checkout scm
            }
        }

        stage('Restore') {
            steps {
                sh 'dotnet restore'
            }
        }

        stage('Build') {
            steps {
                sh 'dotnet build --configuration Release --no-restore'
            }
        }

        stage('Test') {
            steps {
                // Run tests. Produces console output; enable test result collection if desired.
                sh 'dotnet test --configuration Release --no-build --verbosity normal'
            }
        }

        stage('Publish') {
            steps {
                // Publish the web app to a folder for packaging/deployment
                sh 'dotnet publish ./ExampleOrderService/ExampleOrderService.csproj -c Release -o publish --no-restore'
            }
        }

        stage('Build Docker Image') {
            when {
                expression { fileExists('Dockerfile') }
            }
            steps {
                script {
                    def tag = "${DOCKER_IMAGE}:${env.BUILD_NUMBER}"
                    def fullTag = DOCKER_REGISTRY ? "${DOCKER_REGISTRY}/${tag}" : tag
                    sh "docker build -t ${fullTag} ."
                    // also create a 'latest' tag for convenience
                    sh "docker tag ${fullTag} ${DOCKER_REGISTRY ? "${DOCKER_REGISTRY}/${DOCKER_IMAGE}:latest" : "${DOCKER_IMAGE}:latest"}"
                    // expose tags to later stages
                    env.BUILT_IMAGE = fullTag
                }
            }
        }

        stage('Push Docker Image') {
            when {
                allOf {
                    expression { env.DOCKER_REGISTRY?.trim() }
                    expression { env.DOCKER_CREDENTIALS_ID?.trim() }
                }
            }
            steps {
                withCredentials([usernamePassword(credentialsId: env.DOCKER_CREDENTIALS_ID,
                                                 usernameVariable: 'REG_USER',
                                                 passwordVariable: 'REG_PASS')]) {
                    sh "echo \$REG_PASS | docker login ${DOCKER_REGISTRY} --username \$REG_USER --password-stdin"
                    sh "docker push ${env.BUILT_IMAGE}"
                    // push latest as well
                    def latest = "${DOCKER_REGISTRY}/${DOCKER_IMAGE}:latest"
                    sh "docker push ${latest}"
                }
            }
        }
    }

    post {
        always {
            archiveArtifacts artifacts: 'publish/**', allowEmptyArchive: true
            // Optionally collect more logs/test artifacts here
            cleanWs()
        }
    }
}